# Email Campaign Scheduler - Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_CONN_URL=mongodb://localhost:27017/email-scheduler

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_CONN_URL=amqp://guest:guest@localhost:5672

# ============================================
# Logging Configuration
# ============================================
LOG_ERROR=error
LOG_INFO=info
LOG_DEBUG=debug
LOG_API_KEY=your_log_api_key_here
APPLICATION_NAME=email-scheduler
LOGGING_NAME=email-scheduler
LOGGING_LEVEL=1

# ============================================
# AWS SES Configuration (if using AWS SES)
# ============================================
MAIL_AWS_REGION=your_aws_region_here
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here

# ============================================
# Email Configuration
# ============================================
mail_from=noreply@example.com

# ============================================
# Server Configuration
# ============================================
PORT=3000
